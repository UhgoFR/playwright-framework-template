# Environment Configuration
NODE_ENV=development

# Web Testing Configuration
BASE_URL=https://example.com
HEADLESS=false
SLOW_MO=100

# API Testing Configuration
API_BASE_URL=https://api.example.com
API_KEY=your-api-key-here
API_USERNAME=your-username
API_PASSWORD=your-password
API_BEARER_TOKEN=your-bearer-token-here

# Database Configuration (if needed for integration tests)
DATABASE_URL=postgresql://username:password@localhost:5432/testdb
MONGODB_URL=mongodb://localhost:27017/testdb

# External Service Configuration
EXTERNAL_SERVICE_URL=https://external-service.com
EXTERNAL_SERVICE_TOKEN=your-external-service-token

# Test Configuration
TEST_TIMEOUT=60000
RETRY_COUNT=3
PARALLEL_WORKERS=4

# Reporting Configuration
REPORTER_FOLDER=test-results
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=true
TRACE_ON_FAILURE=true

# CI/CD Configuration
CI=false
BUILD_NUMBER=1
TEST_ENVIRONMENT=staging

# Security Configuration
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-encryption-key-here

# Browser Configuration
DEFAULT_BROWSER=chromium
BROWSER_HEADLESS=true
BROWSER_WIDTH=1280
BROWSER_HEIGHT=720

# Mobile Testing Configuration
MOBILE_DEVICE=iPhone 12
TABLET_DEVICE=iPad Pro

# Performance Configuration
PERFORMANCE_BUDGET_LOAD_TIME=5000
PERFORMANCE_BUDGET_FIRST_CONTENTFUL_PAINT=2000
PERFORMANCE_BUDGET_LARGEST_CONTENTFUL_PAINT=2500

# Accessibility Configuration
A11Y_TESTING=true
A11Y_STRICT_MODE=false

# Mock Configuration
ENABLE_MOCKS=false
MOCK_SERVER_URL=http://localhost:3001

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=test-results/test.log
